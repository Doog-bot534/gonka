# Subnet proxy (subnetctl) environment template
#
# Use with:
#   docker compose -f docker-compose.subnetctl.yml up -d subnetctl
#
# Compose-level variables like SUBNET_INSTANCE_NAME and SUBNET_ENV_FILE are
# resolved by Docker Compose itself, so set those in your shell or compose .env
# file if you need them to affect container_name or env_file selection.

# Shared settings
# Gateway runtime topology is bootstrapped from this file only on first start.
# Once /root/.subnetctl/gateway.db exists, subnet membership and gateway settings
# are loaded from that state DB instead of these env values.
export SUBNET_CHAIN_REST=http://node:1317
export SUBNET_PUBLIC_API=http://api:9000
export SUBNET_PORT=8080
export SUBNET_STORAGE_DIR=/root/.subnetctl
export SUBNET_STORAGE_HOST_DIR=.subnetctl
export SUBNET_API_KEYS=sk-your-key-1,sk-your-key-2
export SUBNET_ADMIN_API_KEY=sk-admin-your-key
export GATEWAY_MAX_CONCURRENT_REQUESTS=0
export GATEWAY_MAX_INPUT_TOKENS_IN_FLIGHT=0
export GATEWAY_DEFAULT_MAX_TOKENS=10000

# ---------------------------------------------------------------------------
# Single-subnet mode example
# ---------------------------------------------------------------------------
# Set this in your shell or compose .env if you want the container name:
# export SUBNET_INSTANCE_NAME=subnetctl-12
#
# These values are read inside the container from this env file.
# Keep the storage path aligned with the escrow ID so single and multi mode
# reuse the same persisted state.
#
# export SUBNET_PRIVATE_KEY=<FILLIN>
# export SUBNET_ESCROW_ID=12
# export SUBNET_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507-FP8
# export SUBNET_STORAGE_PATH=/root/.subnetctl/escrow-12/state.db

# ---------------------------------------------------------------------------
# Multi-subnet gateway mode example
# ---------------------------------------------------------------------------
# Set this in your shell or compose .env if you want the container name:
# export SUBNET_INSTANCE_NAME=subnetctl-multi
#
# export SUBNETS_JSON='[
#   {"id":"12","private_key_env":"SUBNET_12_PRIVATE_KEY","model":"Qwen/Qwen3-235B-A22B-Instruct-2507-FP8"},
#   {"id":"13","private_key_env":"SUBNET_13_PRIVATE_KEY","model":"Qwen/Qwen3-235B-A22B-Instruct-2507-FP8"}
# ]'
# export SUBNET_12_PRIVATE_KEY=<FILLIN>
# export SUBNET_13_PRIVATE_KEY=<FILLIN>
